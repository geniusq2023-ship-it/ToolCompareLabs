---
import BaseLayout from './BaseLayout.astro';
import ExpertVerdict from '../components/ExpertVerdict.astro';
import AffiliateButton from '../components/AffiliateButton.astro';
import FaqSection from '../components/FaqSection.astro';
import BottomLine from '../components/BottomLine.astro';
import QuickComparison from '../components/QuickComparison.astro';
import type { BlogSchema } from '../content/blog/schema';

interface FaqItem {
  question: string;
  answer: string;
}

interface ComparisonRow {
  label: string;
  appAValue: string;
  appBValue: string;
  winner?: 'a' | 'b' | 'draw';
}

export interface Props {
  title: string;
  description?: string;
  frontmatter: BlogSchema;
  faqs?: FaqItem[];
  bottomLine?: string;
  quickComparison?: ComparisonRow[];
}

const { title, description, frontmatter, faqs, bottomLine, quickComparison } = Astro.props;
const winnerApp =
  frontmatter.appA.name === frontmatter.winner
    ? frontmatter.appA
    : frontmatter.appB;
---

<BaseLayout
  title={title}
  description={description}
  schemaData={{
    pubDate: frontmatter.pubDate,
    updatedDate: frontmatter.updatedDate,
    category: frontmatter.category,
    winner: frontmatter.winner,
    appA: frontmatter.appA,
    appB: frontmatter.appB,
    verdictReason: frontmatter.verdictReason,
  }}
>
  <div class="mx-auto max-w-7xl px-4 py-10">
    <div class="grid gap-10 lg:grid-cols-[1fr_320px]">
      <article>
        <p class="text-sm font-semibold uppercase tracking-wide text-brand">
          {frontmatter.category}
        </p>
        <h1 class="mt-2 text-3xl font-extrabold text-white md:text-5xl">
          {title}
        </h1>

        <div class="mt-8">
          <ExpertVerdict
            winner={frontmatter.winner}
            verdictReason={frontmatter.verdictReason}
            appA={frontmatter.appA}
            appB={frontmatter.appB}
          />
        </div>
        {bottomLine && <BottomLine text={bottomLine} />}
        {quickComparison && quickComparison.length > 0 && (
          <QuickComparison
            appAName={frontmatter.appA.name}
            appBName={frontmatter.appB.name}
            rows={quickComparison}
          />
        )}

        <div class="prose mt-10 max-w-none">
          <slot />
        </div>

        <slot name="cta" />
        {faqs && faqs.length > 0 && <FaqSection faqs={faqs} />}
      </article>

      <aside class="hidden lg:block">
        <div class="sticky top-6 space-y-6">
          <div class="rounded-xl border border-slate-700 bg-surface-light p-6">
            <p class="text-sm font-semibold uppercase tracking-wide text-slate-400">
              Expert Pick
            </p>
            <p class="mt-2 text-2xl font-bold text-white">{winnerApp.name}</p>
            <p class="mt-2 text-sm text-slate-400">
              {frontmatter.verdictReason}
            </p>
            <div class="mt-4">
              <AffiliateButton
                href={winnerApp.link}
                label={`Try ${winnerApp.name}`}
                variant="success"
                fullWidth
              />
            </div>
          </div>

          <div class="rounded-xl border border-slate-700 bg-surface-light p-6">
            <p class="text-sm font-semibold text-slate-300">Category</p>
            <a
              href={`/${frontmatter.category.toLowerCase().replace(/\s+/g, '-')}`}
              class="mt-1 inline-block text-brand-light hover:text-brand"
            >
              {frontmatter.category}
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
