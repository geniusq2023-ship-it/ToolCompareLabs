---
export interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="mt-8 rounded-lg border-l-4 border-brand bg-brand/5 p-4">
  <p class="text-sm font-semibold uppercase tracking-wide text-brand">Bottom Line</p>
  <p class="mt-1 text-base leading-relaxed text-slate-200">{text}</p>
</div>
