---
interface FaqItem {
  question: string;
  answer: string;
}

export interface Props {
  faqs: FaqItem[];
}

const { faqs } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<div class="mt-12 rounded-xl border border-slate-700 bg-surface-light p-6 md:p-8">
  <h2 class="mb-6 text-2xl font-bold text-white">Frequently Asked Questions</h2>
  <div class="space-y-4">
    {
      faqs.map((faq) => (
        <details class="group rounded-lg border border-slate-700 bg-surface px-4 py-3 open:border-brand/30">
          <summary class="flex cursor-pointer list-none items-center justify-between font-semibold text-slate-200 transition hover:text-white">
            {faq.question}
            <span class="ml-4 text-brand transition group-open:rotate-180">▼</span>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-slate-400">{faq.answer}</p>
        </details>
      ))
    }
  </div>
</div>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
