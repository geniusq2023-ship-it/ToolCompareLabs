---
interface ComparisonRow {
  label: string;
  appAValue: string;
  appBValue: string;
  winner?: 'a' | 'b' | 'draw';
}

export interface Props {
  appAName: string;
  appBName: string;
  rows: ComparisonRow[];
}

const { appAName, appBName, rows } = Astro.props;
---

<div class="mt-8 overflow-hidden rounded-xl border border-slate-700">
  <div class="bg-slate-800 px-4 py-3">
    <p class="text-sm font-semibold uppercase tracking-wide text-slate-300">Quick Comparison</p>
  </div>
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-slate-700 bg-slate-800/50 text-left text-xs uppercase tracking-wide text-slate-400">
        <th class="px-4 py-2">Metric</th>
        <th class="px-4 py-2 text-brand-light">{appAName}</th>
        <th class="px-4 py-2 text-slate-300">{appBName}</th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row, idx) => (
          <tr class={idx % 2 === 0 ? 'bg-surface' : 'bg-slate-800/30'}>
            <td class="px-4 py-2.5 font-medium text-slate-300">{row.label}</td>
            <td class="px-4 py-2.5">
              <span class={row.winner === 'a' ? 'font-semibold text-green-400' : 'text-slate-400'}>
                {row.appAValue}
              </span>
            </td>
            <td class="px-4 py-2.5">
              <span class={row.winner === 'b' ? 'font-semibold text-green-400' : 'text-slate-400'}>
                {row.appBValue}
              </span>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
